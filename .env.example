# ─── Base de données ───────────────────────────────────────────────────────────
POSTGRES_DB=stt_db
POSTGRES_USER=stt_user
POSTGRES_PASSWORD=changeme_strong_password

# ─── Application ───────────────────────────────────────────────────────────────
SECRET_KEY=changeme_long_random_secret_key_here
ENVIRONMENT=production

# ─── Whisper ───────────────────────────────────────────────────────────────────
# Modèles disponibles : tiny, base, small, medium, large-v2, large-v3
# large-v3 = meilleure précision FR (recommandé)
# medium   = bon compromis vitesse/précision
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ─── Fichiers ──────────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MODEL_DIR=/app/models
MAX_UPLOAD_SIZE_MB=500

# ─── HuggingFace (requis pour télécharger le modèle de diarisation pyannote) ──
# Token lisible sur https://huggingface.co/settings/tokens
# Licences à accepter : pyannote/speaker-diarization-3.1 + pyannote/segmentation-3.0
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── CORS (domaines autorisés, séparés par des virgules) ───────────────────────
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000
